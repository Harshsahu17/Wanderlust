<% if(success.length) { %>
    <div 
        class="alert alert-success alert-dismissible fade show col-11 col-sm-8 col-md-6 mx-auto mt-3" 
        role="alert"
    >
        <%= success %>
        <button 
        type="button" 
        class="btn-close" 
        data-bs-dismiss="alert" 
        aria-label="Close"
        ></button>
    </div>
<% } %>
<% if(error.length) { %>
    <div 
        class="alert alert-danger alert-dismissible fade show col-11 col-sm-8 col-md-6 mx-auto mt-3" 
        role="alert"
    >
        <%= error %>
        <button 
        type="button" 
        class="btn-close" 
        data-bs-dismiss="alert" 
        aria-label="Close"
        ></button>
    </div>
<% } %>
