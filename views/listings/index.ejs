<% layout("/layouts/boilerplate") %>

<div class="d-flex justify-content-between align-items-center mt-3">
  <h5 class="mb-0">Explore Listings</h5>
  <a href="/listings" class="btn btn-outline-dark btn-sm d-none" id="clearBtn">
    <i class="fa-solid fa-xmark"></i> Clear Filter
  </a>
</div>

<div id="filters">
  <a href="/listings?category=trending" class="filter">
    <div><i class="fa-solid fa-fire"></i></div>
    <p>Trending</p>
  </a>
  <a href="/listings?category=rooms" class="filter">
    <div><i class="fa-solid fa-bed"></i></div>
    <p>Rooms</p>
  </a>
  <a href="/listings?category=iconic-cities" class="filter">
    <div><i class="fa-solid fa-mountain-city"></i></div>
    <p>Iconic Cities</p>
  </a>
  <a href="/listings?category=mountains" class="filter">
    <div><i class="fa-solid fa-fort-awesome"></i></div>
    <p>Mountains</p>
  </a>
  <a href="/listings?category=castles" class="filter">
    <div><i class="fa-solid fa-chess-rook"></i></div>
    <p>Castles</p>
  </a>
  <a href="/listings?category=amazing-pools" class="filter">
    <div><i class="fa-solid fa-person-swimming"></i></div>
    <p>Amazing Pools</p>
  </a>
  <a href="/listings?category=camping" class="filter">
    <div><i class="fa-solid fa-campground"></i></div>
    <p>Camping</p>
  </a>
  <a href="/listings?category=farms" class="filter">
    <div><i class="fa-solid fa-cow"></i></div>
    <p>Farms</p>
  </a>
  <a href="/listings?category=arctic" class="filter">
    <div><i class="fa-solid fa-snowflake"></i></div>
    <p>Arctic</p>
  </a>
  <a href="/listings?category=beaches" class="filter">
    <div><i class="fa-solid fa-umbrella-beach"></i></div>
    <p>Beaches</p>
  </a>
  <a href="/listings?category=desi-villas" class="filter">
    <div><i class="fa-solid fa-building-columns"></i></div>
    <p>Desi Villas</p>
  </a>

  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input 
        class="form-check-input" 
        type="checkbox" 
        role="switch" 
        id="switchCheckDefault">
      <label 
        class="form-check-label" for="switchCheckDefault"
      >Display total after taxes</label>
    </div>
  </div>
</div>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
  <% if(allListings.length === 0) { %>
    <div class="col-12 text-center mt-5">
      <i class="fa-solid fa-magnifying-glass" style="font-size: 3rem; color: #fe424d;"></i>
      <h4 class="mt-3">No listings found!</h4>
      <p class="text-muted">Try searching something else or
        <a href="/listings" style="color: #fe424d;">view all listings</a>
      </p>
    </div>
  <% } else { %>
    <% for(let listing of allListings) { %>
      <div class="col mb-4">
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <div class="card listing-card">
            <img 
              src="<%= listing.image.url %>" 
              class="card-img-top" 
              alt="listing_image" 
              style="height: 20rem;"
            >
            <div class="card-img-overlay"></div>
            <div class="card-body">
              <p class="card-text">
                <b><%= listing.title %></b>
                <br>
                <span class="base-price">&#8377; <%= listing.price?.toLocaleString("en-IN") %> / night</span>
                <span class="tax-price" style="display:none;">
                  &#8377; <%= Math.round(listing.price * 1.18)?.toLocaleString("en-IN") %> / night
                </span>
                <br>
                <i class="tax-info" style="display:none;">&nbsp;Total price incl. 18% GST</i>
              </p>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  <% } %>
</div>

<script>
  const clearBtn = document.getElementById("clearBtn");
  const urlParams = new URLSearchParams(window.location.search);

  if(urlParams.get("category") || urlParams.get("search")) {
    clearBtn.classList.remove("d-none");
  }

  const activeCategory = urlParams.get("category");
  if(activeCategory) {
    const filters = document.querySelectorAll(".filter");
    filters.forEach(filter => {
      const href = filter.getAttribute("href");
      if(href.includes(activeCategory)) {
        filter.classList.add("active-filter");
      }
    });
  }

  let taxSwitch = document.getElementById("switchCheckDefault");
  let isOn = false;
  taxSwitch.addEventListener("click", () => {
    isOn = !isOn;
    for(let el of document.getElementsByClassName("base-price")){
      el.style.display = isOn ? "none" : "inline";
    }
    for(let el of document.getElementsByClassName("tax-price")){
      el.style.display = isOn ? "inline" : "none";
    }
    for(let el of document.getElementsByClassName("tax-info")){
      el.style.display = isOn ? "inline" : "none";
    }
  });
</script>